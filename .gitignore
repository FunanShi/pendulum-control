# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Virtualenvs
.venv/
venv/

# Test / cache
.pytest_cache/
.ipynb_checkpoints/

# Docker-runtime local files — regenerated by `./run` on every invocation
# (.env holds UID/GID only, no secrets) or redirected here by compose.yaml
# (MPLCONFIGDIR / XDG_CACHE_HOME -> .cache/).
.env
.cache/

# Scenario-runner output — regenerable via `./run batch <scenario>` / `./run ui`;
# never hand-authored. Directory-level rule (not per-extension) so it also covers
# dashboard.png and any future output format with a single line.
artifacts/

# Linter / coverage caches
.coverage
.import_linter_cache/
